# MyMoney888 环境配置示例
# 复制此文件为 .env 并修改配置

# ============ 服务器配置 ============
PORT=8888

# ============ 数据库配置 (MySQL) ============
DB_HOST=localhost
DB_PORT=3306
DB_USER=mymoney888
DB_PASSWORD=your_password
DB_NAME=mymoney888

# ============ 数据持久化配置 ============
# 本地数据备份路径（用于双重保险）
# 留空则使用项目根目录下的 data 目录
DATA_DIR=

# 备份间隔（分钟），0表示禁用自动备份
AUTO_BACKUP_INTERVAL=30

# 每次操作后自动备份
AUTO_BACKUP_ON_CHANGE=true

# ============ 前端配置 ============
VITE_API_URL=http://localhost:8888/api

# ============ Docker部署参数 ============
# 应用端口
APP_PORT=8888

# MySQL端口
MYSQL_PORT=3306

# MySQL root密码
MYSQL_ROOT_PASSWORD=mymoney888

# MySQL数据卷路径（留空使用Docker默认）
# MYSQL_DATA_PATH=/host/path/to/mysql/data

# 应用数据路径（留空使用容器内/data）
# APP_DATA_PATH=/host/path/to/app/data
