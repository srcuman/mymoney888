# MyMoney888 环境配置示例
# 复制此文件为 .env 并修改配置

# ============ 应用配置 ============
PORT=8888
NODE_ENV=production
VITE_API_URL=http://localhost:8888/api

# ============ 数据库配置 (PostgreSQL) ============
# Docker 部署时，如果使用外部数据库，修改以下配置
DB_HOST=localhost           # 数据库主机
DB_PORT=5432               # 数据库端口
DB_USER=postgres            # 数据库用户
DB_PASSWORD=your_password   # 数据库密码
DB_NAME=mymoney888         # 数据库名称

# ============ 数据持久化配置 ============
# 本地数据备份路径（用于双重保险）
# 留空则使用项目根目录下的 data 目录
DATA_DIR=

# 备份间隔（分钟），0表示禁用自动备份
AUTO_BACKUP_INTERVAL=30

# 每次操作后自动备份
AUTO_BACKUP_ON_CHANGE=true

# ============ Docker 部署参数 ============
# 应用端口
APP_PORT=8888

# 外部 PostgreSQL 端口映射（仅在使用内置 PostgreSQL 时需要）
DB_EXTERNAL_PORT=5432
