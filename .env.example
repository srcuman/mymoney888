# MyMoney888 环境配置示例
# 本地开发环境使用，复制为 .env 后修改

# ============ 应用配置 ============
PORT=8888
NODE_ENV=development
VITE_API_URL=http://localhost:8888/api

# ============ 数据库配置 (PostgreSQL) ============
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=mymoney888

# ============ 数据持久化配置 ============
# 本地数据备份路径（用于双重保险）
DATA_DIR=./data

# 备份间隔（分钟），0表示禁用自动备份
AUTO_BACKUP_INTERVAL=30

# 每次操作后自动备份
AUTO_BACKUP_ON_CHANGE=true

# ============ Docker 部署参数 ============
# 应用端口
APP_PORT=8888
