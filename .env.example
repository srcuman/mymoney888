# 数据库配置
# 如果使用外部MySQL数据库，请配置以下变量
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=mymoney888
DB_NAME=mymoney888

# 应用配置
NODE_ENV=production
VITE_API_URL=http://localhost:3000/api

# npm镜像源配置（国内用户已默认使用淘宝镜像）
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com

# 端口配置
APP_PORT=8888

# MySQL服务配置（仅在使用内置MySQL时需要）
MYSQL_ROOT_PASSWORD=mymoney888
MYSQL_DATABASE=mymoney888
MYSQL_USER=mymoney
MYSQL_PASSWORD=mymoney888

# 是否使用外部MySQL数据库（true/false）
USE_EXTERNAL_MYSQL=false
