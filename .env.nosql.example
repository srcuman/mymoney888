# MyMoney888 PostgreSQL 环境配置 (nosql 版本)
# 复制此文件为 .env.nosql 并修改配置
# 此文件仅用于 docker-compose-nosql.yml 部署

# ============ 数据库配置 (PostgreSQL) ============
# 请根据你的 PostgreSQL 服务器配置修改以下值
DB_HOST=你的数据库地址
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=你的数据库密码
DB_NAME=mymoney888

# ============ 应用配置 ============
APP_PORT=8888
